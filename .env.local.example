# ── Site ─────────────────────────────────────────────────────────────────────
# URL pública final do site (sem barra no final) — usado em sitemap, robots e OG
NEXT_PUBLIC_SITE_URL=https://dubaimoveis.com

# ── WordPress REST API ────────────────────────────────────────────────────────
# URL base do WordPress headless (sem barra no final)
# Ex: https://cms.dubaimoveis.com  ou  https://admin.seudominio.com
# Deixe em branco para usar os dados placeholder de desenvolvimento
NEXT_PUBLIC_WP_URL=https://seu-wordpress.com

# ── Vercel Revalidation ───────────────────────────────────────────────────────
# Token secreto para o webhook de revalidação de cache (ISR)
# Gere com: openssl rand -hex 32
# Configure o mesmo token no plugin "WP Webhooks" no painel do WordPress
REVALIDATE_SECRET=troque-por-string-aleatoria-segura

# ── Lead Magnet — Notificação por e-mail ─────────────────────────────────────
# (Opcional) E-mail para receber notificação a cada novo lead capturado
LEAD_NOTIFY_EMAIL=seu@email.com

# ── Brevo (Sendinblue) — opcional ────────────────────────────────────────────
# Para adicionar leads automaticamente a uma lista de e-mail marketing
# BREVO_API_KEY=sua-chave-api
# BREVO_LIST_ID=1
